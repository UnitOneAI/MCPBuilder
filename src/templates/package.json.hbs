{
  "name": "{{name}}",
  "version": "{{version}}",
  "description": "{{description}}",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    {{#if (eq transport 'stdio')}}
    "start": "node dist/index.js",
    {{else}}
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    {{/if}}
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.6.2",
    "axios-retry": "^3.8.0",
    "zod": "^3.22.4"{{#if (eq transport 'http')}},
    "express": "^4.18.2",
    "cors": "^2.8.5"{{/if}}
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    {{#if (eq transport 'http')}}
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    {{/if}}
    "typescript": "^5.2.2",
    "tsx": "^4.7.1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "server",
    "{{transport}}"
  ],
  "author": "UNITONE MCP Builder",
  "license": "MIT"
}
